# ~/.hermes/.env に追記する内容のテンプレート
#
# 使い方: 各値を LINE Developers Console / OA Manager で取得した値に置き換えて、
# このブロックを ~/.hermes/.env に追記してください。
# Claude Code に PROMPTS.md の P3〜P4 を実行させると、自動で書き込まれます。
# 手動で書く場合のみ、このテンプレを参考にしてください。

# === LINE Messaging API ===
# OA Manager → 設定 → Messaging API → Channel secret
LINE_CHANNEL_SECRET=REPLACE_ME_32_HEX_CHARS

# Developers Console → チャネル → Messaging API タブ → Channel access token → Issue
LINE_CHANNEL_ACCESS_TOKEN=REPLACE_ME_LONG_BASE64_STRING

# Developers Console → チャネル → 基本設定 → あなたのユーザーID
# 複数許可するならカンマ区切り
LINE_ALLOWED_USERS=REPLACE_ME_U_PLUS_32_CHARS

# Webhook 受信ポート（Hermes gateway が listen する）
LINE_PORT=8646

# 公開 HTTPS URL（cloudflared tunnel の発行 URL を貼る）
# Claude Code が cloudflared 起動時に自動取得して書き換えるので、初回は空でも OK
LINE_PUBLIC_URL=https://REPLACE_ME.trycloudflare.com

# (任意) cron/通知配信時のデフォルト宛先
# LINE_HOME_CHANNEL=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (任意) 開発時のみ: 全ユーザに応答する (本番では絶対 false)
# LINE_ALLOW_ALL_USERS=false

# (任意) 遅い応答時のポストバックボタン表示までの秒数（既定 45、0 で無効）
# LINE_SLOW_RESPONSE_THRESHOLD=45
