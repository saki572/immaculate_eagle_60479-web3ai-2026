# =====================================================
# 「教えて、minta先生」用 環境変数テンプレ
# =====================================================
# このファイルを `reference-app/.env.local` にコピーして各値を埋める。
#   cd reference-app && cp ../assets/env.template .env.local
# もしくは、`reference-app/.env.local.example` をコピーしてもOK。
#
# ⚠️ .env.local は絶対に Git にコミットしない（.gitignore で除外済）
# ⚠️ シークレットは Claude や ChatGPT のチャットに貼らない（事故ります）
# =====================================================

# --- AI プロバイダ ---
# どちらか1つ設定すれば動く。両方設定した場合は Gemini が優先される。
#
# 推奨: Gemini (Google AI Studio) — 無料枠あり・カード不要
#   取得元: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
#
# フォールバック: OpenAI — 有料（少額課金）
#   取得元: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase ---
# ローカル開発では未設定のままでもOK（履歴機能だけ無効になる）
# Vercel デプロイ時に Vercel Marketplace の「Connect Supabase」で
# 以下の3つは自動で投入される。
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx
